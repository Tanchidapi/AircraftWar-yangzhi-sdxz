<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.AircraftWar" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#0f3460</item>
        <item name="colorPrimaryVariant">#16213e</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#e94560</item>
        <item name="colorSecondaryVariant">#e94560</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#1a1a2e</item>
    </style>

    <!-- 全屏主题（游戏界面用） -->
    <style name="Theme.AircraftWar.Fullscreen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <!-- 允许内容延伸到刘海区域 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
